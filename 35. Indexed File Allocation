#include <stdio.h>

int main() {
    int indexBlock, n, blocks[20], i;

    printf("Enter index block: ");
    scanf("%d", &indexBlock);

    printf("Enter number of blocks: ");
    scanf("%d", &n);

    printf("Enter block numbers:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &blocks[i]);

    printf("\nIndex Block %d contains:\n", indexBlock);

    for(i = 0; i < n; i++)
        printf("%d -> %d\n", i, blocks[i]);

    return 0;
}
